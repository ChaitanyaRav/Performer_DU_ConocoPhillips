{
  "$schema": "https://cloud.uipath.com/draft/2024-12/entry-point",
  "entryPoints": [
    {
      "filePath": "Main-ActionCenter.xaml",
      "uniqueId": "b2af0ead-8cda-482e-a695-fb4195a32373",
      "type": "process",
      "input": {
        "type": "object",
        "properties": {
          "in_TargetFile": {
            "type": "string",
            "description": "The file path of the target document that is going to be processed."
          },
          "in_UseQueue": {
            "type": "boolean",
            "description": "Variable that checks if the Document Understanding Process is using Orchestrator Queues or not.",
            "x-default-expression": "True",
            "default": true
          }
        },
        "required": []
      },
      "output": {
        "type": "object",
        "properties": {
          "out_validationAction": {
            "type": "object",
            "properties": {
              "Id": {
                "$ref": "#/$defs/nullableOfInt64"
              },
              "Status": {
                "enum": [
                  "Unassigned",
                  "Pending",
                  "Completed"
                ]
              },
              "Title": {
                "type": "string"
              },
              "Priority": {
                "enum": [
                  "Low",
                  "Medium",
                  "High",
                  "Critical"
                ]
              },
              "TaskCatalogName": {
                "type": "string"
              },
              "TaskUrl": {
                "type": "string"
              },
              "FolderPath": {
                "type": "string"
              },
              "FolderId": {
                "$ref": "#/$defs/nullableOfInt64"
              },
              "Data": {
                "type": "object"
              },
              "Action": {
                "type": "string"
              },
              "IsDeleted": {
                "type": "boolean"
              },
              "AssignedToUser": {
                "$ref": "#/$defs/userData"
              },
              "CreatorUser": {
                "$ref": "#/$defs/userData"
              },
              "DeleterUser": {
                "$ref": "#/$defs/userData"
              },
              "LastModifierUser": {
                "$ref": "#/$defs/userData"
              },
              "CompletedByUser": {
                "$ref": "#/$defs/userData"
              },
              "CreationTime": {
                "$ref": "#/$defs/nullableOfDateTime"
              },
              "LastAssignedTime": {
                "$ref": "#/$defs/nullableOfDateTime"
              },
              "CompletionTime": {
                "$ref": "#/$defs/nullableOfDateTime"
              },
              "Type": {
                "enum": [
                  "Validation",
                  "Classification"
                ],
                "readOnly": true
              }
            },
            "$defs": {
              "nullableOfInt64": {
                "type": "integer",
                "minimum": -9223372036854775808,
                "maximum": 9223372036854775807
              },
              "userData": {
                "type": "object",
                "properties": {
                  "Id": {
                    "$ref": "#/$defs/nullableOfInt64"
                  },
                  "EmailAddress": {
                    "type": "string"
                  }
                }
              },
              "nullableOfDateTime": {
                "type": "string",
                "format": "date-time"
              }
            },
            "description": "Orchestrator Validation Action that needs to be human-handled in order to continue the process."
          }
        }
      }
    },
    {
      "filePath": "Main-Attended.xaml",
      "uniqueId": "b04e2458-bd39-42ab-b6bb-7c6f8a09988d",
      "type": "process",
      "input": {
        "type": "object",
        "properties": {
          "in_TargetFile": {
            "type": "string",
            "description": "The file path of the target document that is going to be processed."
          },
          "in_UseQueue": {
            "type": "boolean",
            "description": "Variable that checks if the Document Understanding Process is using Orchestrator Queues or not.",
            "x-default-expression": "False",
            "default": false
          }
        },
        "required": []
      }
    }
  ]
}